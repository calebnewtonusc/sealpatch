# SealPatch — Environment Configuration
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub personal access token (needs: repo, security_events scopes)
GITHUB_TOKEN=your_github_token_here

# Anthropic API key (synthesis fallback)
ANTHROPIC_API_KEY=your_anthropic_key_here

# vLLM API key
VLLM_API_KEY=your_vllm_secret_here

# NVD API key (for CVE database access at higher rate limits)
# Free key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_key_here

# ── Optional: Monitoring ───────────────────────────────────────────────────────

WANDB_API_KEY=
HF_TOKEN=

# ── Optional: CI Integrations ─────────────────────────────────────────────────

CIRCLECI_TOKEN=

# ── Optional: Infrastructure ──────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0
VLLM_URLS=http://localhost:8001,http://localhost:8002

# ── Model Paths ───────────────────────────────────────────────────────────────

SEALPATCH_MODEL_PATH=./checkpoints/sealpatch-final
BASE_MODEL=Qwen/Qwen2.5-7B-Coder-Instruct

# ── Scanner Configuration ─────────────────────────────────────────────────────

# Path to Grype binary (if not in PATH)
GRYPE_BIN=grype

# Path to Trivy binary (if not in PATH)
TRIVY_BIN=trivy

# Minimum severity to act on (CRITICAL, HIGH, MEDIUM, LOW)
MIN_SEVERITY=HIGH
